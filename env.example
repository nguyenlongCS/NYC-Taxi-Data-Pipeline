# .env.example
#
# File MẪU — copy thành ".env" (cùng thư mục với docker-compose.yml), rồi
# điền giá trị THẬT trước khi chạy `docker compose up`. File ".env" không
# commit lên Git (đã có trong .gitignore).
#
# Quy tắc: docker-compose.yml CHỈ tham chiếu ${...} tới các biến dưới đây,
# không hardcode và không có giá trị mặc định nào trong docker-compose.yml.
# Muốn đổi bất kỳ giá trị nào (port, user, password...) chỉ cần sửa ở đây,
# không cần đụng vào docker-compose.yml.

# =============================================================
# Postgres (dùng chung cho taxi_dwh VÀ metadata Airflow — airflow_db)
# =============================================================
POSTGRES_USER=taxi_user
POSTGRES_PASSWORD=taxi_pass
POSTGRES_DB=taxi_dwh
# Database "admin" dùng để kết nối vào lúc TẠO airflow_db (không phải
# database chứa dữ liệu) — mặc định Postgres luôn có sẵn database "postgres".
POSTGRES_ADMIN_DB=postgres
# Cổng map ra HOST (cổng bên trong container luôn là 5432, không đổi được
# qua biến này — xem ghi chú trong docker-compose.yml).
POSTGRES_HOST_PORT=5432

# =============================================================
# pgAdmin
# =============================================================
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_HOST_PORT=5050

# =============================================================
# Metabase
# =============================================================
METABASE_HOST_PORT=3000

# =============================================================
# dbt (khi chạy TRÊN HOST bằng venv riêng — xem dbt/README.md, không
# liên quan tới container taxi-dbt của Airflow). Đọc bởi dbt/profiles.yml
# qua env_var(...). Nếu không set, dbt tự dùng giá trị mặc định khớp
# docker-compose.yml (xem comment trong profiles.yml).
# =============================================================
DBT_HOST=localhost
DBT_PORT=5432
DBT_USER=taxi_user
DBT_PASSWORD=taxi_pass
DBT_DBNAME=taxi_dwh

# =============================================================
# Airflow — database & tài khoản admin
# =============================================================
AIRFLOW_DB_NAME=airflow_db

AIRFLOW_ADMIN_USER=admin
# ⚠️ Đổi mật khẩu thật khi deploy, đừng dùng giá trị mẫu này
AIRFLOW_ADMIN_PASSWORD=change_me_please
AIRFLOW_ADMIN_EMAIL=admin@example.com
AIRFLOW_ADMIN_FIRSTNAME=Admin
AIRFLOW_ADMIN_LASTNAME=User

# Airflow dùng key này để mã hoá password/connection lưu trong airflow_db.
# BẮT BUỘC phải là 1 Fernet key hợp lệ (32 byte, base64 urlsafe). Sinh bằng:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Giá trị mẫu dưới đây CHỈ đúng định dạng, KHÔNG được dùng thật — luôn tự
# sinh key riêng, và giữ nguyên giữa các lần "docker compose down/up" (đổi
# key sẽ khiến Airflow không giải mã được connection/password cũ đã lưu).
AIRFLOW_FERNET_KEY=Yqk1IU8G_9O2t5xJZ3nQe7wV6bA0cP4rM8hD1sT9uKk=

# =============================================================
# Airflow — cấu hình vận hành
# =============================================================
AIRFLOW_EXECUTOR=LocalExecutor
AIRFLOW_LOAD_EXAMPLES=false
AIRFLOW_EXPOSE_CONFIG=false
AIRFLOW_WEBSERVER_HOST_PORT=8080
# Giới hạn RAM riêng cho từng container -- tách scheduler/webserver để
# tránh OOM do gộp chung (xem docs/troubleshooting.md).
AIRFLOW_SCHEDULER_MEM_LIMIT=1g
AIRFLOW_WEBSERVER_MEM_LIMIT=1g

# =============================================================
# Airflow — DockerOperator (docker-outside-of-docker)
# =============================================================
# Tên network cố định dùng chung giữa postgres/spark/taxi-loader/taxi-dbt
# và các container do DockerOperator tự tạo (xem airflow/dags/taxi_pipeline_dag.py).
TAXI_DOCKER_NETWORK=taxi_net

# ⚠️ Đường dẫn TUYỆT ĐỐI của project trên máy HOST (không phải trong
# container) — DockerOperator cần giá trị này để mount đúng thư mục
# raw_data/spark_jobs/processed_data/dbt cho các container con nó tạo ra.
# Luôn dùng dấu "/" kể cả trên Windows, ví dụ:
#   HOST_PROJECT_DIR=D:/Project/NYC-Taxi-Data-Pipeline
# Trên Linux/macOS ví dụ:
#   HOST_PROJECT_DIR=/home/ban/NYC-Taxi-Data-Pipeline
HOST_PROJECT_DIR=/duong-dan-tuyet-doi/toi/NYC-Taxi-Data-Pipeline
